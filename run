(def top-help-text
  "run — Workspace helper command groups.

Usage:
  bb run
  bb run <command-group> [args]

Command groups:
  git    Git workspace setup / report / commit helpers.

Options:
  --help, -h    Show this help.

Examples:
  bb run git
  bb run git setup --dry-run
  bb run git report
  bb run git commit --dry-run")

(def git-help-text
  "run git — Bootstrap, inspect, and optionally commit nested git repos.

Usage:
  bb run git
  bb run git setup [options]
  bb run git report [options]
  bb run git commit [options]

Commands:
  setup    Clone/fetch/pull the expected workspace using primary clones plus
           linked worktrees for language branches. Existing paths are validated;
           wrong remotes/branches/topology fail safely.
  report   Show dirty/clean status for all git repos.
  commit   Launch \"pi --print --model deepseek-v4-flash\" with prompt \"commit and push\"
           in each dirty repo.

Common options:
  --root-dir DIR   Use DIR instead of the current working directory.
  --help, -h       Show this help.

Setup options:
  --dry-run        Show clone/worktree/fetch/pull commands without mutating files.

Report options:
  --porcelain      Machine-parseable tab-separated output.

Commit options:
  --dry-run        Show what would be done without actually running pi.

Examples:
  bb run git setup
  bb run git setup --dry-run
  bb run git setup --root-dir /some/other/path
  bb run git report
  bb run git report --porcelain
  bb run git commit --dry-run")

(defn error-result [scope message]
  {:action :error
   :scope scope
   :error message})

(defn parse-git-args [args]
  (cond
    (empty? args)
    {:action :git-help}

    (some help-options args)
    {:action :git-help}

    :else
    (loop [remaining (seq args)
           opts {:root default-root
                 :porcelain? false
                 :dry-run? false
                 :positionals []}]
      (if-not remaining
        (let [[subcommand & extra] (:positionals opts)
              opts (dissoc opts :positionals)]
          (cond
            (nil? subcommand)
            (error-result :git "Missing git subcommand.")

            (not (git-subcommands subcommand))
            (error-result :git (str "Unknown git subcommand: " subcommand))

            (seq extra)
            (error-result :git (str "Unexpected positional argument(s): " (str/join " " extra)))

            (and (= subcommand "report") (:dry-run? opts))
            (error-result :git "--dry-run is only valid for git setup or git commit.")

            (and (or (= subcommand "commit") (= subcommand "setup")) (:porcelain? opts))
            (error-result :git "--porcelain is only valid for git report.")

            :else
            (assoc opts :action :git-run :subcommand subcommand)))
        (let [arg (first remaining)
              rest-args (next remaining)]
          (cond
            (= arg "--root-dir")
            (let [root (first rest-args)]
              (cond
                (nil? root)
                (error-result :git "Missing value for --root-dir.")

                (str/starts-with? root "-")
                (error-result :git "Missing value for --root-dir.")

                :else
                (recur (next rest-args) (assoc opts :root root))))

            (= arg "--porcelain")
            (recur rest-args (assoc opts :porcelain? true))

            (= arg "--dry-run")
            (recur rest-args (assoc opts :dry-run? true))

            (str/starts-with? arg "-")
            (error-result :git (str "Unknown option: " arg))

            :else
            (recur rest-args (update opts :positionals conj arg))))))))

(defn parse-args [args]
  (cond
    (empty? args)
    {:action :top-help}

    (help-options (first args))
    {:action :top-help}

    (= "git" (first args))
    (parse-git-args (rest args))

    (str/starts-with? (first args) "-")
    (error-result :top (str "Unknown option: " (first args)))

    :else
    (error-result :top (str "Unknown command group: " (first args)))))

(defn output-lines [s]
  (if (empty? s)
    []
    (str/split-lines s)))

(defn parent-path [path]
  (some-> path io/file .getParentFile .getPath))

(defn discover-repos [root]
  (let [{:keys [out]} (shell/sh "find" root "-name" ".git" "(" "-type" "d" "-o" "-type" "f" ")" "-print0")]
    (->> (str/split out #"\u0000")
         (remove empty?)
         (map parent-path)
         (remove nil?)
         sort
         vec)))

(defn sh-in [dir & args]
  (apply shell/sh (concat args [:dir dir])))

(defn git-lines [repo & args]
  (let [{:keys [out]} (apply sh-in repo "git" args)]
    (output-lines out)))

(defn git-branch [repo]
  (let [{:keys [exit out]} (sh-in repo "git" "rev-parse" "--abbrev-ref" "HEAD")]
    (if (zero? exit)
      (str/trim-newline out)
      "UNKNOWN")))

(defn rel-path [root repo]
  (let [prefix (str root "/")]
    (if (str/starts-with? repo prefix)
      (subs repo (count prefix))
      repo)))

(defn repo-metadata [root repo]
  (let [branch (git-branch repo)
        tracked-count (count (git-lines repo "ls-files"))
        status-lines (if (zero? tracked-count)
                       []
                       (git-lines repo "status" "--porcelain"))
        dirty-count (count status-lines)
        state (cond
                (zero? tracked-count) :no-tracked-files
                (pos? dirty-count) :dirty
                :else :clean)]
    {:repo repo
     :rel (rel-path root repo)
     :branch branch
     :tracked-count tracked-count
     :status-lines status-lines
     :dirty-count dirty-count
     :state state}))

(defn status-label [xy]
  (case xy
    "M " "modified (staged)"
    " M" "modified (unstaged)"
    "A " "added (staged)"
    "??" "untracked"
    "D " "deleted (staged)"
    " D" "deleted (unstaged)"
    "R " "renamed (staged)"
    "C " "copied (staged)"
    "MM" "modified (staged+unstaged)"
    (str "changed (" xy ")")))

(defn classify-porcelain-line [line]
  (let [xy (if (>= (count line) 2) (subs line 0 2) line)
        path (if (>= (count line) 3) (subs line 3) "")]
    {:xy xy
     :label (status-label xy)
     :path path}))

(defn repo-counts [metas]
  {:total (count metas)
   :dirty (count (filter #(= :dirty (:state %)) metas))
   :clean (count (filter #(= :clean (:state %)) metas))})

(defn human-row [meta]
  (case (:state meta)
    :no-tracked-files
    (format "  ⚠  %s  (%s)  —  no tracked files" (:rel meta) (:branch meta))

    :dirty
    (format "  ✗  %s  (%s)  —  %d dirty file(s)" (:rel meta) (:branch meta) (:dirty-count meta))

    :clean
    (format "  ✓  %s  (%s)  —  clean" (:rel meta) (:branch meta))))

(defn porcelain-row [meta]
  (case (:state meta)
    :no-tracked-files
    (str/join "\t" ["NO-TRACKED-FILES" (:rel meta) (:branch meta)])

    :dirty
    (str/join "\t" ["DIRTY" (:rel meta) (:branch meta) (:dirty-count meta)])

    :clean
    (str/join "\t" ["CLEAN" (:rel meta) (:branch meta)])))

(defn print-report! [{:keys [root porcelain?]} metas]
  (let [{:keys [total dirty clean]} (repo-counts metas)]
    (doseq [meta metas]
      (if porcelain?
        (println (porcelain-row meta))
        (do
          (println (human-row meta))
          (when (= :dirty (:state meta))
            (doseq [line (:status-lines meta)
                    :let [{:keys [label path]} (classify-porcelain-line line)]]
              (printf "       • %s  %s%n" label path))))))
    (if porcelain?
      (println (str/join "\t" ["SUMMARY" (str total " repos") (str dirty " dirty") (str clean " clean")]))
      (do
        (println)
        (println separator)
        (println (format "  Git Dirty Report — %s" root))
        (println (format "  Total repos:  %d" total))
        (println (format "  Dirty:        %d" dirty))
        (println (format "  Clean:        %d" clean))
        (when (pos? dirty)
          (println)
          (println "  Dirty repos:")
          (doseq [meta (filter #(= :dirty (:state %)) metas)]
            (printf "    • %s%n" (:rel meta))))
        (println separator)))))

(defn run-pi! [repo]
  (let [{:keys [exit]} (apply process/shell
                              {:dir repo
                               :in :inherit
                               :out :inherit
                               :err :inherit
                               :continue true}
                              pi-command)]
    exit))

(defn print-command-preview! []
  (println "  (dry-run) would run: pi --print --model deepseek-v4-flash 'commit and push'"))

(defn commit! [{:keys [dry-run?]} metas]
  (let [dirty-metas (vec (filter #(= :dirty (:state %)) metas))
        dirty-count (count dirty-metas)]
    (if (zero? dirty-count)
      (println "No dirty repos to commit. All clean.")
      (do
        (println (format "Running 'pi --print --model deepseek-v4-flash \"commit and push\"' in %d dirty repo(s)..." dirty-count))
        (println)
        (doseq [[i meta] (map-indexed vector dirty-metas)]
          (println separator)
          (println (format "  [%d/%d]  %s  (%s)  —  %d dirty file(s)"
                           i (dec dirty-count) (:rel meta) (:branch meta) (:dirty-count meta)))
          (println)
          (if dry-run?
            (print-command-preview!)
            (let [exit (try
                         (run-pi! (:repo meta))
                         (catch Exception e
                           (binding [*out* *err*]
                             (println (str "Failed to run pi: " (.getMessage e))))
                           1))]
              (when-not (zero? exit)
                (System/exit exit))
              (println)
              (println (format "  Done — exit code: %d" exit)))))
        (println separator)
        (println (format "  Finished. Processed %d dirty repo(s)." dirty-count))))))

(defn setup-root [root]
  (.getAbsolutePath (io/file root)))

(defn workspace-path [root rel]
  (.getPath (io/file root rel)))

(defn file-exists? [path]
  (.exists (io/file path)))

(defn ensure-parent-dir! [path]
  (when-let [parent (.getParentFile (io/file path))]
    (.mkdirs parent)))

(defn git-worktree? [path]
  (and (.isDirectory (io/file path))
       (let [{:keys [exit out]} (sh-in path "git" "rev-parse" "--is-inside-work-tree")]
         (and (zero? exit) (= "true" (str/trim out))))))

(defn primary-clone-path? [path]
  (.isDirectory (io/file path ".git")))

(defn linked-worktree-path? [path]
  (.isFile (io/file path ".git")))

(defn repo-origin-url [repo]
  (let [{:keys [exit out]} (sh-in repo "git" "remote" "get-url" "origin")]
    (when (zero? exit)
      (str/trim-newline out))))

(defn normalize-remote [remote]
  (str/replace (str/trim (or remote "")) #"\.git$" ""))

(defn same-origin? [actual expected]
  (= (normalize-remote actual) (normalize-remote expected)))

(defn local-branch-exists? [repo branch]
  (and (git-worktree? repo)
       (zero? (:exit (sh-in repo "git" "show-ref" "--verify" "--quiet" (str "refs/heads/" branch))))))

(defn ensure-clean-worktree! [{:keys [rel]} path]
  (let [status-lines (git-lines path "status" "--porcelain")]
    (when (seq status-lines)
      (throw (ex-info (format "%s has uncommitted changes; refusing to pull" rel)
                      {:path path
                       :status-lines status-lines})))))

(defn canonical-path [path]
  (.getCanonicalPath (io/file path)))

(defn git-common-dir [repo]
  (let [{:keys [exit out]} (sh-in repo "git" "rev-parse" "--git-common-dir")]
    (when (zero? exit)
      (let [common-dir (str/trim-newline out)
            common-file (io/file common-dir)
            resolved (if (.isAbsolute common-file)
                       common-file
                       (io/file repo common-dir))]
        (.getCanonicalPath resolved)))))

(defn validate-linked-common-dir! [primary-path {:keys [rel]} path]
  (let [actual (git-common-dir path)
        expected (canonical-path (io/file primary-path ".git"))]
    (when-not (= actual expected)
      (throw (ex-info (format "%s belongs to git common dir %s; expected %s" rel (or actual "<missing>") expected)
                      {:path path
                       :common-dir actual
                       :expected expected})))))

(defn shell-quote [s]
  (let [s (str s)]
    (if (re-matches #"[A-Za-z0-9_./:@%+=,-]+" s)
      s
      (str "'" (str/replace s "'" "'\"'\"'") "'"))))

(defn command-preview [dir args]
  (let [cmd (str/join " " (map shell-quote args))]
    (if dir
      (str "cd " (shell-quote dir) " && " cmd)
      cmd)))

(defn inc-count! [counts k]
  (swap! counts update k (fnil inc 0)))

(defn print-setup-row! [mark rel message]
  (println (format "  %s  %-30s  %s" mark rel message)))

(defn run-git-setup-command! [{:keys [dry-run?]} counts dir args]
  (if dry-run?
    (do
      (inc-count! counts :dry-run)
      (println (str "     (dry-run) would run: " (command-preview dir args)))
      0)
    (let [process-opts (cond-> {:in :inherit
                                :out :inherit
                                :err :inherit
                                :continue true}
                         dir (assoc :dir dir))
          {:keys [exit]} (apply process/shell process-opts args)]
      (when-not (zero? exit)
        (throw (ex-info (format "Command failed with exit code %d: %s" exit (command-preview dir args))
                        {:exit exit
                         :dir dir
                         :args args})))
      exit)))

(defn validate-existing-path! [{:keys [remote]} {:keys [rel branch]} path kind]
  (cond
    (not (git-worktree? path))
    (throw (ex-info (format "%s exists but is not a git worktree: %s" rel path) {:path path}))

    (and (= kind :primary) (not (primary-clone-path? path)))
    (throw (ex-info (format "%s must be the primary clone (.git directory), but is not: %s" rel path) {:path path}))

    (and (= kind :linked) (not (linked-worktree-path? path)))
    (throw (ex-info (format "%s must be a linked worktree (.git file), but is not: %s" rel path) {:path path}))

    :else
    (let [origin (repo-origin-url path)
          current-branch (git-branch path)]
      (when-not (same-origin? origin remote)
        (throw (ex-info (format "%s has origin %s; expected %s" rel (or origin "<missing>") remote)
                        {:path path
                         :origin origin
                         :expected remote})))
      (when-not (= branch current-branch)
        (throw (ex-info (format "%s is on branch %s; expected %s" rel current-branch branch)
                        {:path path
                         :branch current-branch
                         :expected branch})))
      true)))

(defn clone-primary! [opts counts {:keys [remote]} {:keys [rel branch]} path]
  (print-setup-row! "＋" rel (str "clone " branch))
  (when-not (:dry-run? opts)
    (ensure-parent-dir! path))
  (run-git-setup-command! opts counts nil ["git" "clone" "--branch" branch remote path])
  (when-not (:dry-run? opts)
    (inc-count! counts :cloned)))

(defn fetch-primary! [opts counts {:keys [rel]} path]
  (print-setup-row! "↻" rel "fetch --prune origin")
  (run-git-setup-command! opts counts path ["git" "fetch" "--prune" "origin"])
  (when-not (:dry-run? opts)
    (inc-count! counts :updated)))

(defn worktree-add-args [primary-path branch path]
  (if (local-branch-exists? primary-path branch)
    ["git" "worktree" "add" path branch]
    ["git" "worktree" "add" "--track" "-b" branch path (str "origin/" branch)]))

(defn add-worktree! [opts counts primary-path {:keys [rel branch]} path]
  (print-setup-row! "＋" rel (str "worktree add " branch))
  (when-not (:dry-run? opts)
    (ensure-parent-dir! path))
  (run-git-setup-command! opts counts primary-path (worktree-add-args primary-path branch path))
  (when-not (:dry-run? opts)
    (inc-count! counts :worktrees-created)))

(defn pull-worktree! [opts counts {:keys [rel branch] :as leaf} path]
  (when (git-worktree? path)
    (ensure-clean-worktree! leaf path))
  (print-setup-row! "↻" rel (str "pull --ff-only origin " branch))
  (run-git-setup-command! opts counts path ["git" "pull" "--ff-only" "origin" branch])
  (when-not (:dry-run? opts)
    (inc-count! counts :updated)))

(defn validate-or-create-primary! [opts counts project primary primary-path]
  (if (file-exists? primary-path)
    (do
      (validate-existing-path! project primary primary-path :primary)
      (inc-count! counts :verified)
      (print-setup-row! "✓" (:rel primary) "validated primary clone"))
    (clone-primary! opts counts project primary primary-path)))

(defn validate-or-create-worktree! [opts counts primary-path project worktree worktree-path]
  (if (file-exists? worktree-path)
    (do
      (validate-existing-path! project worktree worktree-path :linked)
      (validate-linked-common-dir! primary-path worktree worktree-path)
      (inc-count! counts :verified)
      (print-setup-row! "✓" (:rel worktree) "validated linked worktree"))
    (add-worktree! opts counts primary-path worktree worktree-path)))

(defn setup-project! [{:keys [root] :as opts} counts {:keys [name primary worktrees] :as project}]
  (println separator)
  (println (format "  %s" name))
  (let [primary-path (workspace-path root (:rel primary))]
    (validate-or-create-primary! opts counts project primary primary-path)
    (fetch-primary! opts counts primary primary-path)
    (doseq [worktree worktrees
            :let [worktree-path (workspace-path root (:rel worktree))]]
      (validate-or-create-worktree! opts counts primary-path project worktree worktree-path))
    (doseq [leaf (cons primary worktrees)
            :let [leaf-path (workspace-path root (:rel leaf))]]
      (pull-worktree! opts counts leaf leaf-path))))

(defn print-setup-summary! [root counts]
  (let [{:keys [cloned worktrees-created updated verified dry-run errors]} counts]
    (println)
    (println separator)
    (println (format "  Git Setup — %s" root))
    (println (format "  Cloned:             %d" (or cloned 0)))
    (println (format "  Worktrees created:  %d" (or worktrees-created 0)))
    (println (format "  Existing verified:  %d" (or verified 0)))
    (println (format "  Updated:            %d" (or updated 0)))
    (println (format "  Dry-run commands:   %d" (or dry-run 0)))
    (println (format "  Errors:             %d" (or errors 0)))
    (println separator)))

(defn setup! [{:keys [root] :as opts}]
  (let [root (setup-root root)
        opts (assoc opts :root root)
        counts (atom {:cloned 0
                      :worktrees-created 0
                      :updated 0
                      :verified 0
                      :dry-run 0
                      :errors 0})]
    (println (format "Setting up BigConfig git workspace under %s%s"
                     root
                     (if (:dry-run? opts) " (dry-run)" "")))
    (doseq [project workspace-projects]
      (try
        (setup-project! opts counts project)
        (catch Exception e
          (inc-count! counts :errors)
          (binding [*out* *err*]
            (println (format "  ✗  %s  %s" (:name project) (.getMessage e)))))))
    (print-setup-summary! root @counts)
    (when (pos? (:errors @counts))
      (System/exit 1))))

(defn help-text-for [scope]
  (case scope
    :git git-help-text
    top-help-text))

(defn print-error! [{:keys [scope error]}]
  (binding [*out* *err*]
    (println error)
    (println)
    (println (help-text-for scope))))

(defn run-git-command! [{:keys [root subcommand] :as opts}]
  (case subcommand
    "setup"
    (setup! opts)

    (let [repos (discover-repos root)]
      (if (empty? repos)
        (do
          (println (format "No git repositories found under %s" root))
          (System/exit 1))
        (let [metas (mapv #(repo-metadata root %) repos)]
          (case subcommand
            "commit" (commit! opts metas)
            "report" (print-report! opts metas)))))))

(defn -main [& args]
  (let [{:keys [action] :as opts} (parse-args args)]
    (case action
      :top-help
      (println top-help-text)

      :git-help
      (println git-help-text)

      :error
      (do
        (print-error! opts)
        (System/exit 1))

      :git-run
      (run-git-command! opts))))

(apply -main *command-line-args*)
