#!/usr/bin/env bb

(ns run
  (:require [babashka.process :as process]
            [clojure.java.io :as io]
            [clojure.java.shell :as shell]
            [clojure.string :as str]))

(def default-root (System/getProperty "user.dir"))
(def git-subcommands #{"report" "commit" "setup"})
(def help-options #{"--help" "-h"})
(def separator "──────────────────────────────────────────")
(def pi-command ["pi" "--print" "--model" "deepseek-v4-flash" "commit and push"])

